# MySQL server configuration
MYSQL_HOST=database
MYSQL_PORT=3306
MYSQL_DATABASE=mautic
MYSQL_USER=mautic
MYSQL_PASSWORD=mautic
MYSQL_ROOT_PASSWORD=mautic

# Docker Mautic configuration (container runtimre behavior)
DOCKER_MAUTIC_RUN_MIGRATIONS=false
DOCKER_MAUTIC_ENABLE_EMAIL_FETCH=false

# Advanced configuration (alternative to config/local.php)
# Uses official Mautic support for MAUTIC_CONFIG_PARAMETERS
# Uncomment if you want to configure Mautic purely via ENV
#
# MAUTIC_CONFIG_PARAMETERS={"db_driver":"pdo_mysql","db_host":"${MYSQL_HOST}","db_port":${MYSQL_PORT},"db_name":"${MYSQL_DATABASE}","db_user":"${MYSQL_USER}","db_password":"${MYSQL_PASSWORD}","db_table_prefix":null,"db_backup_tables":1,"db_backup_prefix":"bak_"}
